# Copy to .env and fill in.

# LiveKit project (same values used by revotext-meet-design Next.js app)
LIVEKIT_URL=wss://revo-test-ui-4zvndup0.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# STT mode: "local" (faster-whisper, free, runs on this machine)
#       or "api" (OpenAI Whisper API, paid, ~$0.006/min)
WHISPER_MODE=local

# Local Whisper model — tiny.en (fastest, lowest accuracy)
#                       base.en (recommended for prototype)
#                       small.en, medium.en, large-v3 (higher accuracy, slower)
WHISPER_MODEL=base.en

# Compute type for faster-whisper: int8 (CPU-friendly), int8_float16, float16 (GPU)
WHISPER_COMPUTE=int8

# Only needed if WHISPER_MODE=api
# OPENAI_API_KEY=
